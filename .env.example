# Database — same Supabase project as commission-automation (evgmeszyxjzrrbrzznhv)
# Tables live in PostgreSQL schema "energy4solar" (commission data stays in "public")
DATABASE_URL="postgresql://postgres.evgmeszyxjzrrbrzznhv:[password]@aws-1-us-west-2.pooler.supabase.com:5432/postgres"
DIRECT_URL="postgresql://postgres.evgmeszyxjzrrbrzznhv:[password]@aws-1-us-west-2.pooler.supabase.com:5432/postgres"
SUPABASE_URL=https://evgmeszyxjzrrbrzznhv.supabase.co

# Zoho Books OAuth (never expose to frontend)
ZOHO_CLIENT_ID=
ZOHO_CLIENT_SECRET=
ZOHO_REFRESH_TOKEN=
ZOHO_ORGANIZATION_ID=868942267
ZOHO_ACCOUNTS_DOMAIN=accounts.zoho.com
ZOHO_API_DOMAIN=www.zohoapis.com
ZOHO_BOOKS_BASE_URL=https://www.zohoapis.com/books/v3

# Affiliate URLs built during sync
AFFILIATE_BASE_URL=https://bigbattery.com
AFFILIATE_UTM_SOURCE=energy4solar
AFFILIATE_UTM_MEDIUM=affiliate

# Site
SITE_URL=https://www.energy4solar.com
CORS_ORIGINS=https://www.energy4solar.com,http://localhost:3000

# Security
CRON_SECRET=generate-a-long-random-string
ADMIN_USERNAME=admin
ADMIN_PASSWORD=your-secure-password
ADMIN_API_KEY=generate-a-long-random-string

# Estimated commission % for earnings dashboard (default 5)
AFFILIATE_COMMISSION_PCT=5

# WooCommerce — product images from bigbattery.com (Store API is public; v3 optional)
WOO_STORE_URL=https://bigbattery.com
WOO_CONSUMER_KEY=
WOO_CONSUMER_SECRET=
# Set true to fetch og:image for SKUs missing from Woo (slow; use scripts/enrich-images)
WOO_IMAGE_OG_FALLBACK=false

# BigBattery media import (Pressable — Admin → Sync → Import product images)
MEDIA_IMPORT_PROTOCOL=sftp
MEDIA_IMPORT_HOST=sftp.pressable.com
MEDIA_IMPORT_PORT=22
MEDIA_IMPORT_USER=
MEDIA_IMPORT_PASSWORD=
MEDIA_IMPORT_REMOTE_PATH=/wp-content/uploads
MEDIA_IMPORT_PUBLIC_URL=https://bigbattery.com/wp-content/uploads

# Optional — for TanStack Query client in monorepo setups
NEXT_PUBLIC_API_URL=http://localhost:3001
