# Database (Supabase PostgreSQL)
DATABASE_URL="postgresql://postgres.[ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres?pgbouncer=true"
DIRECT_URL="postgresql://postgres.[ref]:[password]@aws-0-[region].pooler.supabase.com:5432/postgres"

# Zoho Books OAuth (never expose to frontend)
ZOHO_CLIENT_ID=
ZOHO_CLIENT_SECRET=
ZOHO_REFRESH_TOKEN=
ZOHO_ORGANIZATION_ID=868942267
ZOHO_ACCOUNTS_DOMAIN=accounts.zoho.com
ZOHO_API_DOMAIN=www.zohoapis.com
ZOHO_BOOKS_BASE_URL=https://www.zohoapis.com/books/v3

# Affiliate URLs built during sync
AFFILIATE_BASE_URL=https://bigbattery.com
AFFILIATE_UTM_SOURCE=energy4solar
AFFILIATE_UTM_MEDIUM=affiliate

# Site
SITE_URL=https://www.energy4solar.com
CORS_ORIGINS=https://www.energy4solar.com,http://localhost:3000

# Security
CRON_SECRET=generate-a-long-random-string
ADMIN_API_KEY=generate-a-long-random-string

# Optional — for TanStack Query client in monorepo setups
NEXT_PUBLIC_API_URL=http://localhost:3001
